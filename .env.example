# Copy this file to .env and fill in real values. Never commit .env itself.

# Supabase → Project Settings → Data API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase → Project Settings → API Keys → service_role (secret) key.
# This key bypasses Row Level Security — server-side only, never send it to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Password you pick to sign in at /admin.html to review pending signups.
ADMIN_PASSWORD=pick-a-real-password

# Your own email — when you sign up with this exact address, your account
# skips the review queue and is verified instantly. Everyone else still
# goes through the normal manual-review flow.
ADMIN_EMAIL=you@example.com

# Optional — defaults to 3000.
PORT=3000
